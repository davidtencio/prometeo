# URL del Gateway de OpenClaw en tu VPS
OPENCLAW_GATEWAY_URL=http://2.24.212.81:18789

# Token de autenticacion del Gateway (opcional)
OPENCLAW_TOKEN=

# Clave secreta para proteger el proxy interno.
# En produccion se recomienda definirla siempre.
PROXY_SECRET=cambia_esto_por_una_clave_segura_aleatoria

# Lista opcional de origenes CORS permitidos (separados por coma).
# Ejemplo: https://mi-app.vercel.app,https://admin.midominio.com
PROXY_ALLOWED_ORIGINS=
