# Copiar este archivo como .env.local para desarrollo,
# o configurar estas variables en Vercel (Project Settings → Environment Variables).

# --- Conexión con OpenClaw (mini PC vía túnel) ---
# URL del endpoint de OpenClaw. Si se deja vacío, /api/chat responde en modo simulado.
OPENCLAW_API_URL=
# Token opcional que se envía como "Authorization: Bearer ..." hacia OpenClaw.
OPENCLAW_API_KEY=

# --- Autenticación de la web app ---
# Si AMBAS están vacías, la app queda ABIERTA (solo para desarrollo local).
# En producción, definir las dos SIEMPRE.

# Contraseña para iniciar sesión.
APP_PASSWORD=
# Secreto para firmar la cookie de sesión. Generar uno largo y aleatorio, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
