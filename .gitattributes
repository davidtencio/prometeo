# Normaliza finales de línea: LF en el repositorio.
# Evita los warnings de CRLF en Windows y mantiene consistencia entre SO.
* text=auto eol=lf

# Archivos binarios (sin conversión de finales de línea).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
